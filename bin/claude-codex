#!/usr/bin/env bash
# claude-codex — bridge-holic launcher
#
# Starts claude-code-proxy-headless if not running, then launches Claude Code
# with ANTHROPIC_BASE_URL pointing at the proxy so all model requests go to Codex.
#
# Environment variables (all optional — defaults shown):
#   BRIDGE_HOLIC_PROXY_BIN   path to claude-code-proxy-headless binary
#                            default: $HOME/.local/bin/claude-code-proxy-headless
#   CLAUDE_CODE_PROXY_PORT   proxy listen port        default: 18765
#   CLAUDE_CODE_PROXY_MODEL  main Codex model         default: gpt-5.4
#   CLAUDE_CODE_PROXY_SMALL  small/fast model         default: gpt-5.4-mini
#
# Usage: claude-codex [--full-tools] [claude args...]
#   --full-tools   enable all Claude Code tools (MCP, Agent, etc.)
#                  default: light tool set (Bash,Read,Edit,Write)

set -euo pipefail

PROXY_BIN="${BRIDGE_HOLIC_PROXY_BIN:-$HOME/.local/bin/claude-code-proxy-headless}"
PROXY_PORT="${CLAUDE_CODE_PROXY_PORT:-18765}"
PROXY_URL="http://127.0.0.1:${PROXY_PORT}"
CODEX_MODEL="${CLAUDE_CODE_PROXY_MODEL:-gpt-5.4}"
CODEX_SMALL="${CLAUDE_CODE_PROXY_SMALL:-gpt-5.4-mini}"
CODEX_TMPDIR="${CLAUDE_CODE_PROXY_TMPDIR:-/tmp/claude-codex-$(id -u)-${PROXY_PORT}-${CODEX_MODEL}}"
TOOL_MODE="light"
LIGHT_TOOLS="Bash,Read,Edit,Write"

prepare_claude_tmpdir() {
  local dir="$1" owner uid mode acl_mode
  uid="$(id -u)"
  case "$dir" in
    *[[:space:]]*)
      echo "ERROR: refusing tmpdir path with whitespace: $dir" >&2
      exit 1
      ;;
  esac
  if [[ -L "$dir" ]]; then
    echo "ERROR: refusing symlink tmpdir: $dir" >&2
    exit 1
  fi
  if [[ ! -d "$dir" ]]; then
    mkdir -m 700 -p "$dir"
  fi
  if [[ -L "$dir" ]]; then
    echo "ERROR: refusing symlink tmpdir after mkdir: $dir" >&2
    exit 1
  fi
  owner="$(stat -f %u "$dir" 2>/dev/null || true)"
  if [[ "$owner" != "$uid" ]]; then
    echo "ERROR: tmpdir owner mismatch: $dir owner=$owner expected=$uid" >&2
    exit 1
  fi
  mode="$(stat -f %Lp "$dir" 2>/dev/null || true)"
  if [[ "$mode" != "700" ]]; then
    echo "ERROR: insecure tmpdir mode: $dir mode=$mode expected=700; remove it and retry" >&2
    exit 1
  fi
  acl_mode="$(ls -lde "$dir" 2>/dev/null | awk '{print $1}' || true)"
  if [[ "$acl_mode" == *+* ]]; then
    echo "ERROR: refusing tmpdir with ACL: $dir" >&2
    exit 1
  fi
}

prepare_claude_tmpdir "$CODEX_TMPDIR"

claude_extra_args=()
passthrough_args=()
while (( $# > 0 )); do
  case "$1" in
    --full-tools)
      TOOL_MODE="full"
      shift ;;
    *)
      passthrough_args+=("$1")
      shift ;;
  esac
done

# ── ensure proxy is running ────────────────────────────────────────────────────
if ! curl -sf --max-time 1 "${PROXY_URL}/healthz" >/dev/null 2>&1; then
  if [[ ! -x "$PROXY_BIN" ]]; then
    echo "ERROR: claude-code-proxy-headless not found at $PROXY_BIN" >&2
    echo "Install it first: https://github.com/raine/claude-code-proxy" >&2
    exit 1
  fi
  echo "Starting claude-code-proxy..." >&2
  PORT="$PROXY_PORT" CCP_AUTH_STORE=file CCP_CODEX_IMPORT_CODEX_AUTH=1 \
    "$PROXY_BIN" serve >> /tmp/ccp.log 2>&1 &
  for _ in {1..30}; do
    curl -sf --max-time 1 "${PROXY_URL}/healthz" >/dev/null 2>&1 && break
    sleep 0.2
  done
  if ! curl -sf --max-time 1 "${PROXY_URL}/healthz" >/dev/null 2>&1; then
    echo "ERROR: proxy did not start. Check /tmp/ccp.log" >&2
    exit 1
  fi
fi

# ── build settings JSON ────────────────────────────────────────────────────────
SETTINGS=$(python3 -c "
import json, sys
print(json.dumps({
    'permissions': {'defaultMode': 'bypassPermissions'},
    'skipDangerousModePermissionPrompt': True,
    'env': {
        'ANTHROPIC_BASE_URL': '$PROXY_URL',
        'ANTHROPIC_AUTH_TOKEN': 'unused',
        'ANTHROPIC_MODEL': '$CODEX_MODEL',
        'ANTHROPIC_SMALL_FAST_MODEL': '$CODEX_SMALL',
        'CLAUDE_CODE_DISABLE_NONSTREAMING_FALLBACK': '1',
    }
}, separators=(',', ':')))
")

if [[ "$TOOL_MODE" == "light" ]]; then
  claude_extra_args+=(--strict-mcp-config --tools "$LIGHT_TOOLS")
fi

claude_extra_args+=(
  --disallowedTools "Task(codex-research),Task(codex-reader),Task(codex-coder),Task(codex-reviewer)"
)

# claude-codex 세션은 Codex 강제 위임 OFF로 시작한다.
# 강제 위임은 /codex-on 명령이 세션별 codex_mode_on 파일을 만들 때만 켜진다.
exec env CLAUDE_CODE_TMPDIR="$CODEX_TMPDIR" claude \
  --settings "$SETTINGS" \
  --model "$CODEX_MODEL" \
  "${claude_extra_args[@]}" \
  "${passthrough_args[@]}"
